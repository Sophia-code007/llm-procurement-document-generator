{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "采购需求结构化数据 Schema",
  "description": "用于校验采购需求解析模型输出，字段命名与 API、模板占位符保持一致。",
  "type": "object",
  "required": ["requirementData"],
  "additionalProperties": false,
  "properties": {
    "requirementData": {
      "type": "object",
      "required": [
        "purchaseProjectName",
        "purchaseOrgName",
        "purchaseContactPerson",
        "purchaseContactPhone",
        "purchaseMethod",
        "purchaseCategory",
        "totalBudgetAmount",
        "fundSource",
        "purchaseItemList",
        "setMaxPriceLimit",
        "maxPriceAmount",
        "quoteScope",
        "taxRateRequire",
        "deliveryAddress",
        "deliveryDeadline",
        "acceptanceStandard",
        "paymentMode",
        "advancePaymentRatio",
        "finalPaymentTerm",
        "warrantyPeriod",
        "afterServiceResponse",
        "docObtainStartTime",
        "docObtainEndTime",
        "bidDeadline",
        "bidOpenAddress",
        "needBidBond",
        "bidBondAmount",
        "isGovernmentProcurement",
        "allowSubcontract",
        "ipOwnershipRequire",
        "otherSpecialRequirement"
      ],
      "additionalProperties": false,
      "properties": {
        "purchaseProjectName": { "type": ["string", "null"], "description": "采购项目名称" },
        "purchaseOrgName": { "type": ["string", "null"], "description": "采购组织单位" },
        "purchaseContactPerson": { "type": ["string", "null"], "description": "采购联系人" },
        "purchaseContactPhone": { "type": ["string", "null"], "description": "联系电话" },
        "purchaseMethod": {
          "type": ["string", "null"],
          "enum": ["openTender", "competitiveConsultation", "inquiry", "singleSource", "frameworkAgreement", null],
          "description": "采购方式"
        },
        "purchaseCategory": {
          "type": ["string", "null"],
          "enum": ["goods", "service", "project", "integration", null],
          "description": "采购类别"
        },
        "totalBudgetAmount": { "type": ["number", "null"], "description": "预算总金额，单位元" },
        "fundSource": { "type": ["string", "null"], "description": "资金来源" },
        "purchaseItemList": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["itemName", "itemModel", "techRequirement", "quantity", "unit", "allowImportGoods"],
            "additionalProperties": false,
            "properties": {
              "itemName": { "type": "string", "description": "标的物名称" },
              "itemModel": { "type": ["string", "null"], "description": "规格型号" },
              "techRequirement": { "type": ["string", "null"], "description": "技术参数要求" },
              "quantity": { "type": ["number", "null"], "description": "主采购数量" },
              "unit": { "type": ["string", "null"], "description": "主采购单位" },
              "allowImportGoods": { "type": ["boolean", "null"], "description": "是否允许进口产品" }
            }
          }
        },
        "setMaxPriceLimit": { "type": ["boolean", "null"], "description": "是否设置最高限价" },
        "maxPriceAmount": { "type": ["number", "null"], "description": "最高限价金额，单位元" },
        "quoteScope": { "type": ["string", "null"], "description": "报价包含范围" },
        "taxRateRequire": { "type": ["string", "null"], "description": "税率要求" },
        "deliveryAddress": { "type": ["string", "null"], "description": "交付地点" },
        "deliveryDeadline": { "type": ["string", "null"], "description": "交付/完工期限" },
        "acceptanceStandard": { "type": ["string", "null"], "description": "验收标准" },
        "paymentMode": {
          "type": ["string", "null"],
          "enum": ["advanceProgressFinal", "acceptanceOneTime", "other", null],
          "description": "付款方式"
        },
        "advancePaymentRatio": { "type": ["number", "null"], "description": "预付款比例，百分比数值" },
        "finalPaymentTerm": { "type": ["string", "null"], "description": "尾款支付时限" },
        "warrantyPeriod": { "type": ["string", "null"], "description": "质保期限" },
        "afterServiceResponse": { "type": ["string", "null"], "description": "售后响应要求" },
        "docObtainStartTime": { "type": ["string", "null"], "description": "招标文件获取开始时间" },
        "docObtainEndTime": { "type": ["string", "null"], "description": "招标文件获取截止时间" },
        "bidDeadline": { "type": ["string", "null"], "description": "投标截止时间" },
        "bidOpenAddress": { "type": ["string", "null"], "description": "开标地点" },
        "needBidBond": { "type": ["boolean", "null"], "description": "是否需要保证金" },
        "bidBondAmount": { "type": ["number", "null"], "description": "保证金金额，单位元" },
        "isGovernmentProcurement": { "type": ["boolean", "null"], "description": "是否属于政府采购项目" },
        "allowSubcontract": { "type": ["boolean", "null"], "description": "是否允许分包转包" },
        "ipOwnershipRequire": { "type": ["string", "null"], "description": "知识产权归属要求" },
        "otherSpecialRequirement": { "type": ["string", "null"], "description": "其他特殊需求" }
      }
    }
  }
}
