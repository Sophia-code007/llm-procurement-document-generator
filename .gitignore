# ==============================
# 全局通用 - 前端 Node 相关
# ==============================
# 依赖目录
node_modules/
*/node_modules/

# 打包产物
dist/
*/dist/
build/
*/build/

# 环境变量
.env.local
.env
.env.*
!.env.example

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
/logs/

# 运行缓存
pids
*.pid
*.seed
*.pid.lock

# 测试覆盖率
coverage/
*.lcov

# 包管理器锁文件（保留package-lock.json，过滤其他）
yarn.lock
pnpm-lock.yaml

# 工具缓存
.eslintcache
*.tsbuildinfo
.swc

# ==============================
# 全局通用 - IDE、系统临时文件
# ==============================
.vscode/
.idea/
*.swp
*.swo
*~

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

tmp/
temp/
.playwright-cli/

# ==============================
# 全局通用 - Python / FastAPI 后端
# ==============================
# 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
venv/
.venv/
env/
ENV/

# 静态检查/测试缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==============================
# 密钥、证书文件（全局屏蔽）
# ==============================
*.pem
*.key

# ==============================
# 项目分层精准过滤（适配你的仓库目录）
# 只过滤对应文件夹内的产物，不影响其他目录同名文件
# ==============================
# 后端专属：数据库、输出文件夹
backend/*.db
backend/*.sqlite
backend/*.sqlite3
backend/output/
backend/outputs/

# 全局生成文件
generated/
outputs/
exports/

# 项目自定义Agent缓存
.agent/